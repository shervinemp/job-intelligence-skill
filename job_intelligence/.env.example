# JI_TAILOR — CV generation backend.
# Default is "agent" (SLM-in-the-loop). Set to "gem" to use Gemini Web gem instead.
# JI_TAILOR=agent
# JI_TAILOR=gem

# GEM_ID — Only needed if JI_TAILOR=gem.
# Find your gem ID in the URL when you open the gem:
#   https://gemini.google.com/gem/<GEM_ID>
# GEM_ID=<your_gem_id_here>
