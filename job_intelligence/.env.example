# JI_TAILOR — Tailoring backend: "gem" for Gemini Web gem, "agent" for SLM-in-the-loop.
# Default is "gem". Set to "agent" to have the SLM generate scripts directly.
# JI_TAILOR=gem

# GEM_ID — Only needed if JI_TAILOR=gem.
# Find your gem ID in the URL when you open it:
#   https://gemini.google.com/gem/<GEM_ID>
# GEM_ID=<your_gem_id_here>
