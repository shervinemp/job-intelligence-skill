# === Pipeline Configuration ===
# Copy this file to .env and edit values.
# Already-set process environment vars take precedence over .env values.

# JI_HOME — root directory for all pipeline data (state DB, results, snapshots,
# Chrome profile). Default: ~/.ji/
# JI_HOME=C:\ji-data

# JI_TAILOR — CV generation backend.
# "agent" (default): SLM-in-the-loop — writes script.py, confirms with `done --pdf`
# "gem": uses Gemini Web gem (requires Chrome automation)
# JI_TAILOR=agent

# GMAIL_SEARCH_QUERY — Gmail search filter for stage_emails.py
# GMAIL_SEARCH_QUERY=label:Jobs OR from:linkedin OR from:indeed OR subject:job

# === LLM API (optional) ===
# LLM_API_URL — OpenAI-compatible endpoint for lib/ask_api.py.
# LLM_API_URL=http://localhost:8080/v1
#
# LLM_API_MODEL — model name sent in API requests (optional)
# LLM_API_MODEL=
